PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/hank
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=20000
NODE_ENV=development

# VAPID keys for web push. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Default timezone is set per-user in the app (Settings → Timezone).
# Default is Australia/Brisbane. No env var needed.

# ── Strava (Run plan auto-sync) ──────────────────────────────────────
# Create a free app at https://www.strava.com/settings/api
#   Authorization Callback Domain = your app's domain (e.g. hank.up.railway.app
#   for prod, or localhost for local dev).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Public base URL of this app (used to build the OAuth redirect + webhook URL).
# e.g. https://hank.up.railway.app  — falls back to the request host if unset.
PUBLIC_URL=
# Optional explicit override of the OAuth redirect (defaults to PUBLIC_URL/api/strava/callback).
STRAVA_REDIRECT_URI=
# Any random string; must match what Strava echoes back when verifying the webhook.
STRAVA_WEBHOOK_VERIFY_TOKEN=hank-strava-verify
